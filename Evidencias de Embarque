<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Evidencias de Embarque</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<style>

:root{
--dhl-red:#d40511;
--dhl-yellow:#ffcc00;
--background:#f4f6f8;
--card:#ffffff;
--border:#e1e5ea;
--text:#2c3e50;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI,Arial,sans-serif;
}

body{
background:var(--background);
color:var(--text);
padding-bottom:100px;
}

.header{
background:linear-gradient(90deg,var(--dhl-yellow),#ffd633);
padding:18px;
border-bottom:4px solid var(--dhl-red);
position:sticky;
top:0;
z-index:10;
}

.header h1{font-size:22px;}
.header small{display:block;margin-top:5px;}

.container{
max-width:900px;
margin:auto;
padding:15px;
}

.embarque-card{
background:white;
border-radius:18px;
box-shadow:0 5px 20px rgba(0,0,0,.1);
margin-bottom:20px;
overflow:hidden;
}

.embarque-title{
padding:15px;
background:#fafafa;
color:var(--dhl-red);
font-weight:bold;
font-size:18px;
}

.section{
padding:18px;
}

.section-title{
font-size:14px;
font-weight:bold;
margin-bottom:15px;
color:var(--dhl-red);
}

input, select{
width:100%;
padding:13px;
border-radius:12px;
border:1px solid var(--border);
font-size:15px;
margin-bottom:10px;
}

.photo-grid{
display:grid;
grid-template-columns:1fr;
gap:15px;
}

@media(min-width:700px){
.photo-grid{
grid-template-columns:repeat(3,1fr);
}
}

.photo-card{
border:1px solid var(--border);
border-radius:15px;
padding:12px;
background:#fafafa;
}

.preview{
width:100%;
height:200px;
object-fit:cover;
border-radius:12px;
margin-top:10px;
}

button{
border:0;
border-radius:14px;
padding:15px;
font-weight:bold;
cursor:pointer;
}

.btn-photo{width:100%;background:#003b75;color:white;}
.btn-add{width:100%;background:#0b7d3b;color:white;}
.btn-remove{width:100%;background:#d40511;color:white;}
.btn-pdf{width:100%;background:#d40511;color:white;font-size:17px;}

.fixed{
position:fixed;
bottom:0;
left:0;
right:0;
padding:12px;
background:white;
box-shadow:0 -3px 10px #ddd;
}

</style>

</head>

<body>

<div class="header">
<h1>Evidencias de Embarque</h1>
<small>DHL Supply Chain | Registro de Evidencias</small>
</div>

<div class="container">

<div id="progress" style="font-weight:bold;margin:10px 0;padding:10px;background:#fff;border-radius:10px;">
Embarques: 0
</div>

<div id="embarquesContainer"></div>

<button class="btn-add" onclick="agregarEmbarque()">+ Agregar embarque</button>

<div style="display:flex;gap:10px;margin-top:10px;">
<button onclick="irAnterior()" style="flex:1;padding:12px;">⬅ Anterior</button>
<button onclick="irSiguiente()" style="flex:1;padding:12px;">Siguiente ➡</button>
</div>

</div>

<div class="fixed">
<button class="btn-pdf" onclick="generarPDF()">Generar PDF</button>
</div>

<!-- BOTONES FLOTANTES -->
<div style="
position:fixed;
right:10px;
bottom:90px;
display:flex;
flex-direction:column;
gap:10px;
z-index:9999;
">

<button onclick="window.scrollTo({top:0,behavior:'smooth'})"
style="padding:12px;border-radius:50%;width:50px;height:50px;background:#000;color:white;">
↑
</button>

<button onclick="window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'})"
style="padding:12px;border-radius:50%;width:50px;height:50px;background:#000;color:white;">
↓
</button>

</div>

<script>

const STORAGE_KEY="embarques_storage_v1";
let embarques=[];
let actual = 0;

function guardar(){
localStorage.setItem(STORAGE_KEY,JSON.stringify(embarques));
}

function cargar(){
let data=localStorage.getItem(STORAGE_KEY);

if(data){
embarques=JSON.parse(data);
}else{
embarques.push({
cuadrilla:"",
cortina:"",
unidad:"",
destino:"",
fotoInicio:"",
fotoMedio:"",
fotoFin:""
});
}
render();
}

function agregarEmbarque(){
embarques.push({
cuadrilla:"",
cortina:"",
unidad:"",
destino:"",
fotoInicio:"",
fotoMedio:"",
fotoFin:""
});
guardar();
render();
}

function eliminar(index){
embarques.splice(index,1);
guardar();
render();
}

function actualizar(index,campo,valor){
embarques[index][campo]=valor;
guardar();
}

function validarUnidad(input,index){
let valor=input.value;
if(valor.length>10) input.value=valor.slice(0,10);
actualizar(index,"unidad",input.value);
}

function render(){

document.getElementById("progress").innerText =
"Embarques: " + embarques.length;

let cont=document.getElementById("embarquesContainer");
cont.innerHTML="";

embarques.forEach((e,i)=>{

cont.innerHTML+=`

<div class="embarque-card">

<div class="embarque-title" id="emp-${i}">
EMBARQUE #${i+1}
</div>

<div class="section">

<div class="section-title">BLOQUE 1 - DATOS</div>

<label>CUADRILLA</label>
<select onchange="actualizar(${i},'cuadrilla',this.value)">
<option value="">Seleccione</option>
<option value="A" ${e.cuadrilla=="A"?"selected":""}>A</option>
<option value="B" ${e.cuadrilla=="B"?"selected":""}>B</option>
<option value="C" ${e.cuadrilla=="C"?"selected":""}>C</option>
<option value="D" ${e.cuadrilla=="D"?"selected":""}>D</option>
</select>

<label>CORTINA</label>
<input value="${e.cortina}"
oninput="this.value=this.value.slice(0,3)"
onchange="actualizar(${i},'cortina',this.value)">

<label>UNIDAD</label>
<input value="${e.unidad}"
oninput="validarUnidad(this,${i})">

<label>DESTINO</label>
<select onchange="actualizar(${i},'destino',this.value)">
<option value="">Seleccione</option>
<option value="ONEST" ${e.destino=="ONEST"?"selected":""}>ONEST</option>
<option value="DHL" ${e.destino=="DHL"?"selected":""}>DHL</option>
<option value="CLIENTE" ${e.destino=="CLIENTE"?"selected":""}>CLIENTE</option>
</select>

</div>

<div class="section">
<div class="section-title">BLOQUE 2 - FOTOS</div>

<div class="photo-grid">
${fotoHTML(i,"fotoInicio","INICIO",e.fotoInicio)}
${fotoHTML(i,"fotoMedio","MEDIO",e.fotoMedio)}
${fotoHTML(i,"fotoFin","FINAL",e.fotoFin)}
</div>
</div>

<div class="section">
<button class="btn-remove" onclick="eliminar(${i})">Eliminar</button>
</div>

</div>

`;

});
}

function fotoHTML(index,campo,titulo,imagen){
return `
<div class="photo-card">

<b>${titulo}</b>

<input type="file" accept="image/*" capture="environment"
id="${campo}${index}" style="display:none"
onchange="cargarFoto(event,${index},'${campo}')">

<button class="btn-photo"
onclick="document.getElementById('${campo}${index}').click()">
Tomar foto
</button>

${imagen ? `<img class="preview" src="${imagen}">` : ""}

</div>
`;
}

async function cargarFoto(event,index,campo){
let file=event.target.files[0];
if(!file)return;

let img=await comprimir(file,1600,0.75);

embarques[index][campo]=img;
guardar();
render();
}

function comprimir(file,max,quality){
return new Promise(res=>{
let r=new FileReader();
r.onload=e=>{
let img=new Image();
img.onload=()=>{
let c=document.createElement("canvas");
let ratio=Math.min(max/img.width,max/img.height);
c.width=img.width*ratio;
c.height=img.height*ratio;
c.getContext("2d").drawImage(img,0,0,c.width,c.height);
res(c.toDataURL("image/jpeg",quality));
};
img.src=e.target.result;
};
r.readAsDataURL(file);
});
}

function irSiguiente(){
if(actual < embarques.length - 1){
actual++;
irA(actual);
}
}

function irAnterior(){
if(actual > 0){
actual--;
irA(actual);
}
}

function irA(i){
const cards=document.querySelectorAll(".embarque-card");
if(cards[i]){
cards[i].scrollIntoView({behavior:"smooth",block:"start"});
}
}

function generarPDF(){

const {jsPDF}=window.jspdf;
let pdf=new jsPDF("landscape","mm","a4");

embarques.forEach((e,i)=>{

if(i>0) pdf.addPage();

pdf.setFillColor(255,204,0);
pdf.rect(0,0,297,210,"F");

pdf.setFontSize(18);
pdf.setTextColor(180,0,20);

pdf.text("CORTINA: "+(e.cortina||""),15,20);
pdf.text("UNIDAD: "+(e.unidad||""),95,20);
pdf.text("DESTINO: "+(e.destino||""),220,20);

const fotos=[e.fotoInicio,e.fotoMedio,e.fotoFin];
const tit=["INICIO","MEDIO","FINAL"];
const pos=[10,106,202];

for(let j=0;j<3;j++){
if(fotos[j]){
pdf.addImage(fotos[j],"JPEG",pos[j],40,85,120);
}
pdf.setFontSize(12);
pdf.setTextColor(0,0,0);
pdf.text(tit[j],pos[j]+42,165,{align:"center"});
}

});

pdf.save("Evidencia_Embarque.pdf");
}

cargar();

</script>

</body>
</html>
